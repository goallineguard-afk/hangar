# Copy this file to .env and fill in your own values.

# Token from @BotFather on Telegram
BOT_TOKEN=123456:ABC-DEF...

# Where uploaded files get stored. Either:
#  - your own numeric Telegram user ID (get it from @userinfobot), or
#  - a private channel ID where your bot is an admin (starts with -100...)
STORAGE_CHAT_ID=

# Password to open the Hangar dashboard — change this
APP_PASSWORD=changeme

# Long random string for signing sessions — change this
SECRET_KEY=replace-with-a-long-random-string

# Optional — Flask reads this automatically on most hosts
PORT=5000
